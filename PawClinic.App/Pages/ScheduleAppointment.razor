@page "/appointments/schedule"

<div class="page-header">
    <span style="font-size:1.6rem">📅</span>
    <h3>Schedule Appointment</h3>
</div>

<div class="row">
    <div class="col-12 col-lg-6">
        <div class="card p-1">
            <div class="card-body">

                <div class="mb-3">
                    <label class="form-label fw-semibold">Owner</label>
                    <select class="form-select" @onchange="OnOwnerChanged">
                        <option value="">-- Select owner --</option>
                        @foreach (var owner in Owners)
                        {
                            <option value="@owner.OwnerId">@owner.Name</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Pet</label>
                    <select class="form-select" @bind="SelectedPetId" disabled="@(Pets.Count == 0)">
                        <option value="">@(SelectedOwnerId == Guid.Empty ? "Select an owner first" : Pets.Count == 0 ? "No pets for this owner" : "-- Select pet --")</option>
                        @foreach (var pet in Pets)
                        {
                            <option value="@pet.PetId">@pet.Name (@pet.Species)</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Vet</label>
                    <select class="form-select" @bind="SelectedVetId">
                        <option value="">-- Select vet --</option>
                        @foreach (var vet in Vets)
                        {
                            <option value="@vet.VetId">@vet.Name — @vet.Specialisation</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Date &amp; Time</label>
                    <input type="datetime-local" class="form-control"
                        @bind="ScheduledDateTime"
                        @bind:format="yyyy-MM-ddTHH:mm" />
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">Reason for Visit</label>
                    <input type="text" class="form-control" placeholder="Annual check-up, vaccination…"
                        @bind="ReasonForVisit" />
                </div>

                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="alert alert-danger mb-3">@ErrorMessage</div>
                }

                <div class="d-flex gap-2">
                    <button class="btn btn-primary" @onclick="HandleSubmit">📅 Schedule</button>
                    <a href="/appointments" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </div>
        </div>
    </div>
</div>
