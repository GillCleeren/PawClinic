@page "/login"

<div class="d-flex justify-content-center align-items-start mt-5">
    <div class="card" style="width:100%;max-width:440px">
        <div class="card-header text-center py-3">
            <div style="font-size:2.5rem">🐾</div>
            <h4 class="mb-0 mt-1" style="font-weight:700;color:var(--paw-green-900)">Sign in to PawClinic</h4>
            <p class="text-muted mb-0" style="font-size:0.85rem">Your trusted veterinary companion</p>
        </div>
        <div class="card-body p-4">
            <EditForm Model="@LoginViewModel" OnValidSubmit="HandleValidSubmit">
                <div class="mb-3">
                    <label class="form-label fw-semibold" for="email">Email address</label>
                    <InputText id="email" class="form-control" placeholder="you@example.com" @bind-Value="LoginViewModel.Email" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold" for="password">Password</label>
                    <InputText type="password" id="password" class="form-control" placeholder="••••••••" @bind-Value="LoginViewModel.Password" />
                </div>
                <div class="d-grid mt-4">
                    <button class="btn btn-primary btn-lg">🔑 Sign In</button>
                </div>
                <div class="text-center mt-3">
                    <a href="/register" class="btn btn-link">Don't have an account? Register</a>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(Message))
{
    <div class="alert alert-danger mt-3 text-center">@Message</div>
}
