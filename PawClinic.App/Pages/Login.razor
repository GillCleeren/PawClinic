@page "/login"

<div class="mt-5 row">
    <div class="card col-12 col-lg-6 me-auto ms-auto p-3">
        <h3 class="card-title">Login to PawClinic</h3>
        <div class="card-body">
            <EditForm Model="@LoginViewModel" OnValidSubmit="HandleValidSubmit">
                <div class="row mt-2">
                    <label class="col-12 col-md-4 p-0 form-label" for="email">Email:</label>
                    <div class="col-12 col-md-8">
                        <InputText id="email" class="form-control" @bind-Value="LoginViewModel.Email" />
                    </div>
                </div>
                <div class="row mt-2">
                    <label class="col-12 col-md-4 p-0 form-label" for="password">Password:</label>
                    <div class="col-12 col-md-8">
                        <InputText type="password" id="password" class="form-control" @bind-Value="LoginViewModel.Password" />
                    </div>
                </div>
                <div class="row mt-2">
                    <div class="offset-md-4">
                        <button class="btn btn-primary m-2 ms-0">Login</button>
                        <a href="/register" class="btn btn-link">Register</a>
                    </div>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(Message))
{
    <div class="alert alert-danger mt-3 text-center">@Message</div>
}
