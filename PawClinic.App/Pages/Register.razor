@page "/register"

<div class="d-flex justify-content-center align-items-start mt-5">
    <div class="card" style="width:100%;max-width:480px">
        <div class="card-header text-center py-3">
            <div style="font-size:2.5rem">🐾</div>
            <h4 class="mb-0 mt-1" style="font-weight:700;color:var(--paw-green-900)">Create your account</h4>
            <p class="text-muted mb-0" style="font-size:0.85rem">Join PawClinic and start managing your clinic</p>
        </div>
        <div class="card-body p-4">
            <EditForm Model="@RegisterViewModel" OnValidSubmit="HandleValidSubmit">
                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label class="form-label fw-semibold" for="firstName">First Name</label>
                        <InputText id="firstName" class="form-control" @bind-Value="RegisterViewModel.FirstName" />
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-semibold" for="lastName">Last Name</label>
                        <InputText id="lastName" class="form-control" @bind-Value="RegisterViewModel.LastName" />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold" for="userName">Username</label>
                    <InputText id="userName" class="form-control" @bind-Value="RegisterViewModel.UserName" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold" for="email">Email address</label>
                    <InputText id="email" class="form-control" placeholder="you@example.com" @bind-Value="RegisterViewModel.Email" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold" for="password">Password</label>
                    <InputText type="password" id="password" class="form-control" placeholder="••••••••" @bind-Value="RegisterViewModel.Password" />
                </div>
                <div class="d-grid mt-4">
                    <button class="btn btn-primary btn-lg">✏️ Create Account</button>
                </div>
                <div class="text-center mt-3">
                    <a href="/login" class="btn btn-link">Already have an account? Sign in</a>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(Message))
{
    <div class="alert alert-danger mt-3 text-center">@Message</div>
}
