@page "/owners/{OwnerId:guid}/pets/add"

<div class="page-header">
    <span style="font-size:1.6rem">🐾</span>
    <h3>Add Pet</h3>
</div>

<div class="row">
    <div class="col-12 col-lg-6">
        <div class="card p-1">
            <div class="card-body">
                <EditForm Model="@Pet" OnValidSubmit="HandleValidSubmit">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="mb-3">
                        <label class="form-label fw-semibold" for="name">Pet Name</label>
                        <InputText id="name" class="form-control" placeholder="Buddy" @bind-Value="Pet.Name" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold" for="species">Species</label>
                        <InputSelect id="species" class="form-select" @bind-Value="SelectedSpecies">
                            <option value="0">Dog</option>
                            <option value="1">Cat</option>
                            <option value="2">Rabbit</option>
                            <option value="3">Bird</option>
                            <option value="4">Other</option>
                        </InputSelect>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold" for="breed">Breed <span class="text-muted fw-normal">(optional)</span></label>
                        <InputText id="breed" class="form-control" placeholder="Golden Retriever" @bind-Value="Pet.Breed" />
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold" for="dob">Date of Birth</label>
                        <InputDate id="dob" class="form-control" @bind-Value="Pet.DateOfBirth" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">🐾 Add Pet</button>
                        <a href="/owners/@OwnerId" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(Message))
{
    <div class="alert alert-danger mt-3">@Message</div>
}
