@page "/"

<PageTitle>PawClinic — Veterinary Management</PageTitle>

<div class="hero-section">
    <h1>Welcome to PawClinic 🐾</h1>
    <p>Caring for every paw, claw, and tail — all in one place.</p>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card feature-card h-100">
            <div class="card-body">
                <span class="feature-icon">🐕</span>
                <h5 class="card-title">Pet Owners</h5>
                <p class="card-text text-muted">Register and manage pet owners, view their furry family members, and keep contact info up to date.</p>
                <a href="/owners" class="btn btn-primary mt-2">Go to Owners</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card feature-card h-100">
            <div class="card-body">
                <span class="feature-icon">📅</span>
                <h5 class="card-title">Appointments</h5>
                <p class="card-text text-muted">Track upcoming vet visits, check-ups, and procedures. Never miss a scheduled appointment.</p>
                <a href="/appointments" class="btn btn-primary mt-2">Go to Appointments</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card feature-card h-100">
            <div class="card-body">
                <span class="feature-icon">🐕</span>
                <h5 class="card-title">Pets</h5>
                <p class="card-text text-muted">Add and manage pets for each owner. Track species, breed, and date of birth — all linked to their owner profile.</p>
                <a href="/pets" class="btn btn-primary mt-2">Go to Pets</a>
            </div>
        </div>
    </div>
</div>
