@page "/"

<PageTitle>PawClinic</PageTitle>

<h1>Welcome to PawClinic</h1>

<p>Manage your veterinary clinic with ease.</p>

<div class="row mt-4">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Owners</h5>
                <p class="card-text">View and manage pet owners.</p>
                <a href="/owners" class="btn btn-primary">Go to Owners</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Appointments</h5>
                <p class="card-text">View upcoming appointments.</p>
                <a href="/appointments" class="btn btn-primary">Go to Appointments</a>
            </div>
        </div>
    </div>
</div>
