@page "/owners/{OwnerId:guid}"

<div class="page-header">
    <span style="font-size:1.6rem">🐾</span>
    <h3>Owner Detail</h3>
</div>

@if (Owner == null)
{
    <div class="loading-paw">
        <div>🐶</div>
        <p>Loading owner details…</p>
    </div>
}
else
{
    <div class="card mb-4">
        <div class="card-body d-flex gap-3 align-items-start">
            <div class="owner-card">
                <div class="owner-avatar">🧑</div>
            </div>
            <div class="flex-grow-1">
                <h5 class="card-title mb-1" style="font-weight:700;color:var(--paw-green-900)">@Owner.Name</h5>
                <p class="card-text mb-1">
                    <span class="text-muted">📧</span>
                    <span class="ms-1">@Owner.Email</span>
                </p>
                <p class="card-text mb-1">
                    <span class="text-muted">📞</span>
                    <span class="ms-1">@Owner.PhoneNumber</span>
                </p>
                <p class="card-text mb-0">
                    <span class="text-muted">📍</span>
                    <span class="ms-1">@Owner.Address</span>
                </p>
            </div>
        </div>
    </div>

    <div class="page-header mt-2">
        <span style="font-size:1.4rem">🐕</span>
        <h4 style="margin:0;font-weight:700;color:var(--paw-green-900)">Pets</h4>
    </div>

    @if (!Pets.Any())
    {
        <div class="card p-4 text-center text-muted">
            <div style="font-size:2.5rem">🐾</div>
            <p class="mt-2 mb-0">No pets registered for this owner yet.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Pet</th>
                        <th>Species</th>
                        <th>Breed</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var pet in Pets)
                    {
                        <tr>
                            <td><strong>@pet.Name</strong></td>
                            <td>
                                <span class="pet-species-icon">@GetSpeciesEmoji(pet.Species)</span>
                                @pet.Species
                            </td>
                            <td>@pet.Breed</td>
                            <td>
                                @if (pet.IsArchived)
                                {
                                    <span class="badge-status badge-cancelled">Archived</span>
                                }
                                else
                                {
                                    <span class="badge-status badge-scheduled">Active</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

