@page "/appointments"

<div class="page-header">
    <span style="font-size:1.6rem">📅</span>
    <h3>Upcoming Appointments</h3>
    <a href="/appointments/schedule" class="btn btn-primary btn-sm ms-auto">+ Schedule</a>
</div>

@if (Appointments == null)
{
    <div class="loading-paw">
        <div>🐶</div>
        <p>Loading appointments…</p>
    </div>
}
else if (!Appointments.Any())
{
    <div class="card p-4 text-center text-muted">
        <div style="font-size:3rem">🐾</div>
        <p class="mt-2 mb-0">No upcoming appointments scheduled.</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>🗓 Date &amp; Time</th>
                    <th>🐾 Pet</th>
                    <th>🩺 Vet</th>
                    <th>Reason</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var appt in Appointments)
                {
                    <tr>
                        <td>@appt.ScheduledDateTime.ToString("g")</td>
                        <td><strong>@appt.PetName</strong></td>
                        <td>@appt.VetName</td>
                        <td>@appt.ReasonForVisit</td>
                        <td>
                            <span class="badge-status @GetStatusClass(appt.Status)">@appt.Status</span>
                        </td>
                        <td>
                            <a href="/appointments/@appt.AppointmentId" class="btn btn-outline-secondary btn-sm">View</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

