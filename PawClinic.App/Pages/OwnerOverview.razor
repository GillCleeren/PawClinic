@page "/owners"

<div class="page-header">
    <span style="font-size:1.6rem">🐾</span>
    <h3>Pet Owners</h3>
</div>

<a href="/owners/add" class="btn btn-primary mb-4">
    ➕ Register New Owner
</a>

@if (Owners == null)
{
    <div class="loading-paw">
        <div>🐶</div>
        <p>Loading owners…</p>
    </div>
}
else if (!Owners.Any())
{
    <div class="card p-4 text-center text-muted">
        <div style="font-size:3rem">🐾</div>
        <p class="mt-2 mb-0">No owners registered yet. Add the first one!</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone Number</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var owner in Owners)
                {
                    <tr>
                        <td><strong>@owner.Name</strong></td>
                        <td>@owner.Email</td>
                        <td>@owner.PhoneNumber</td>
                        <td>
                            <a href="/owners/@owner.OwnerId" class="btn btn-sm btn-outline-primary">View 🐾</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
