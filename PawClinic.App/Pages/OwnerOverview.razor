@page "/owners"

<h3>Owner Overview</h3>

<br />

<a href="/owners/add" class="btn btn-primary mb-3">Register New Owner</a>

@if (Owners == null)
{
    <p><em>Loading...</em></p>
}
else if (!Owners.Any())
{
    <p>No owners found.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone Number</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var owner in Owners)
            {
                <tr>
                    <td>@owner.Name</td>
                    <td>@owner.Email</td>
                    <td>@owner.PhoneNumber</td>
                    <td>
                        <a href="/owners/@owner.OwnerId" class="btn btn-sm btn-outline-primary">View</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
